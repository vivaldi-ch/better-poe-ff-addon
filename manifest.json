{
  "manifest_version": 3,
  "name": "Better PoE Trading",
  "version": "0.1.0",
  "description": "POC Contextual bookmarking system for Path of Exile Trade",
  "browser_specific_settings": {
    "gecko": {
      "id": "@better-poe-trade.vivaldi-ch",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://www.pathofexile.com/trade/*",
        "*://pathofexile.com/trade/*"
      ],
      "js": [
        "src/content.ts"
      ]
    }
  ]
}

